{
    "behavior_definitions": {
        "GoToStation": {
            "type": "Sequence",
            "name": "GoToStationRoot",
            "variables": {
                "sx": { "type": "float", "init": 0.0 },
                "sy": { "type": "float", "init": 0.0 },
                "sz": { "type": "float", "init": 0.0 },
                "tx": { "type": "float", "init": 0.0 },
                "ty": { "type": "float", "init": 0.0 },
                "tz": { "type": "float", "init": 0.0 }
            },
            "children": [
                {
                    "type": "Action",
                    "name": "ObserveCurrentPosition",
                    "command": "NO_OP",
                    "observation": {
                        "sx": "POS_X",
                        "sy": "POS_Y",
                        "sz": "POS_Z"
                    }
                },
                {
                    "type": "Action",
                    "name": "MoveToStation",
                    "command": "MOVE_TO",
                    "params": {
                        "x": "${tx}",
                        "y": "${ty}",
                        "z": "${tz}"
                    }
                },
                {
                    "type": "Selector",
                    "name": "CheckArrival",
                    "children": [
                        {
                            "type": "Sequence",
                            "name": "HandleArrival",
                            "children": [
                                {
                                    "type": "Condition",
                                    "name": "HasReachedStation",
                                    "expression": "sx == tx && sy == ty && sz == tz"
                                },
                                {
                                    "type": "Action",
                                    "name": "AdvanceToNextTask",
                                    "command": "NEXT_TASK"
                                }
                            ]
                        },
                        {
                            "type": "Action",
                            "name": "WaitForArrival",
                            "command": "NO_OP"
                        }
                    ]
                },
                {
                    "type": "Action",
                    "name": "EmitMoveCommand",
                    "command": "EMIT_COMMAND",
                    "params": {
                        "CMD_X": "${tx}",
                        "CMD_Y": "${ty}",
                        "CMD_Z": "${tz}"
                    }
                }
            ]
        },
        "Search": {
            "type": "Sequence",
            "name": "SearchRoot",
            "constants": {
                "inf": { "type": "float", "value": 1000000.0 },
                "target": { "type": "string", "value": "alpha" },
                "target_true": { "type": "string", "value": "alpha_true" }
            },
            "variables": {
                "x": { "type": "float", "init": 0.0 },
                "y": { "type": "float", "init": 0.0 },
                "z": { "type": "float", "init": 0.0 },
                "tx": { "type": "float", "init": 0.0 },
                "ty": { "type": "float", "init": 0.0 },
                "tz": { "type": "float", "init": 0.0 },
                "dist": { "type": "float", "init": 0.0 },
                "min_dist": { "type": "float", "init": 1000000.0 },
                "dx": { "type": "float", "init": 0.0 },
                "dy": { "type": "float", "init": 0.0 },
                "dz": { "type": "float", "init": 0.0 },
                "is_target": { "type": "bool", "init": false },
                "is_light": { "type": "bool", "init": false },
                "rec_type": { "type": "string", "init": "" },
                "rec_type_true": { "type": "string", "init": "" }
            },
            "children": [
                {
                    "type": "Action",
                    "name": "ObserveSearchInputs",
                    "command": "NO_OP",
                    "observation": {
                        "rec_type": "REC",
                        "rec_type_true": "REC_TRUE",
                        "x": "POS_X",
                        "y": "POS_Y",
                        "z": "POS_Z",
                        "tx": "TARGET_X",
                        "ty": "TARGET_Y",
                        "tz": "TARGET_Z"
                    }
                },
                {
                    "type": "Action",
                    "name": "UpdateTargetMatchFlag",
                    "command": "ASSIGN",
                    "params": {
                        "is_target": "rec_type == target"
                    }
                },
                {
                    "type": "Selector",
                    "name": "BroadcastDetectedTarget",
                    "children": [
                        {
                            "type": "Sequence",
                            "name": "HandleDetectedTarget",
                            "children": [
                                {
                                    "type": "Condition",
                                    "name": "IsDetectedTarget",
                                    "expression": "is_target == true"
                                },
                                {
                                    "type": "Action",
                                    "name": "ComputeDetectedTargetDistance",
                                    "command": "ASSIGN",
                                    "params": {
                                        "dx": "x - tx",
                                        "dy": "y - ty",
                                        "dz": "z - tz",
                                        "dist": "sqrt(dx * dx + dy * dy + dz * dz)"
                                    }
                                },
                                {
                                    "type": "Action",
                                    "name": "SendDetectedTarget",
                                    "command": "SEND",
                                    "params": {
                                        "x": "${x}",
                                        "y": "${y}",
                                        "z": "${z}",
                                        "min_dist": "${dist}",
                                        "is_target": true
                                    }
                                }
                            ]
                        },
                        {
                            "type": "Action",
                            "name": "SkipTargetBroadcast",
                            "command": "NO_OP"
                        }
                    ]
                },
                {
                    "type": "Action",
                    "name": "ReceiveSharedTarget",
                    "command": "RECEIVE",
                    "params": {
                        "tx": "${tx}",
                        "ty": "${ty}",
                        "tz": "${tz}",
                        "min_dist": "${min_dist}",
                        "is_target": "${is_target}",
                        "result_to": "is_target"
                    }
                },
                {
                    "type": "Selector",
                    "name": "RefreshSharedTargetDistance",
                    "children": [
                        {
                            "type": "Sequence",
                            "name": "HandleSharedTarget",
                            "children": [
                                {
                                    "type": "Condition",
                                    "name": "HasSharedTarget",
                                    "expression": "is_target == true"
                                },
                                {
                                    "type": "Action",
                                    "name": "ComputeSharedTargetDistance",
                                    "command": "ASSIGN",
                                    "params": {
                                        "dx": "x - tx",
                                        "dy": "y - ty",
                                        "dz": "z - tz",
                                        "dist": "sqrt(dx * dx + dy * dy + dz * dz)"
                                    }
                                }
                            ]
                        },
                        {
                            "type": "Action",
                            "name": "SkipDistanceRefresh",
                            "command": "NO_OP"
                        }
                    ]
                },
                {
                    "type": "Selector",
                    "name": "MoveToBestTarget",
                    "children": [
                        {
                            "type": "Sequence",
                            "name": "HandleCloserTarget",
                            "children": [
                                {
                                    "type": "Condition",
                                    "name": "IsCloserThanBestTarget",
                                    "expression": "dist < min_dist"
                                },
                                {
                                    "type": "Action",
                                    "name": "UpdateBestDistance",
                                    "command": "ASSIGN",
                                    "params": {
                                        "min_dist": "dist"
                                    }
                                },
                                {
                                    "type": "Action",
                                    "name": "ShareBestDistance",
                                    "command": "SEND",
                                    "params": {
                                        "x": "${x}",
                                        "y": "${y}",
                                        "z": "${z}",
                                        "min_dist": "${dist}",
                                        "is_target": true
                                    }
                                },
                                {
                                    "type": "Action",
                                    "name": "MoveToCloserTarget",
                                    "command": "MOVE_TO",
                                    "params": {
                                        "x": "${tx}",
                                        "y": "${ty}",
                                        "z": "${tz}"
                                    }
                                }
                            ]
                        },
                        {
                            "type": "Sequence",
                            "name": "HandleEqualBestTarget",
                            "children": [
                                {
                                    "type": "Condition",
                                    "name": "MatchesBestDistance",
                                    "expression": "dist == min_dist"
                                },
                                {
                                    "type": "Action",
                                    "name": "MoveToEqualBestTarget",
                                    "command": "MOVE_TO",
                                    "params": {
                                        "x": "${tx}",
                                        "y": "${ty}",
                                        "z": "${tz}"
                                    }
                                }
                            ]
                        },
                        {
                            "type": "Action",
                            "name": "HoldPosition",
                            "command": "NO_OP"
                        }
                    ]
                },
                {
                    "type": "Selector",
                    "name": "ConfirmAndReportTarget",
                    "children": [
                        {
                            "type": "Sequence",
                            "name": "HandleConfirmedTarget",
                            "children": [
                                {
                                    "type": "Condition",
                                    "name": "HasReachedTargetPosition",
                                    "expression": "x == tx && y == ty && z == tz"
                                },
                                {
                                    "type": "Condition",
                                    "name": "IsTrueTarget",
                                    "expression": "rec_type_true == target_true"
                                },
                                {
                                    "type": "Action",
                                    "name": "ReportTrueTarget",
                                    "command": "REPORT_TARGET",
                                    "params": {
                                        "x": "${tx}",
                                        "y": "${ty}",
                                        "z": "${tz}"
                                    }
                                },
                                {
                                    "type": "Action",
                                    "name": "EnableLightSignal",
                                    "command": "ASSIGN",
                                    "params": {
                                        "is_light": true
                                    }
                                },
                                {
                                    "type": "Action",
                                    "name": "ExitAfterTargetReport",
                                    "command": "EXIT"
                                }
                            ]
                        },
                        {
                            "type": "Action",
                            "name": "ContinueTargetSearch",
                            "command": "NO_OP"
                        }
                    ]
                },
                {
                    "type": "Action",
                    "name": "EmitLightCommand",
                    "command": "EMIT_COMMAND",
                    "params": {
                        "LIGHT": "${is_light}"
                    }
                }
            ]
        }
    }
}
