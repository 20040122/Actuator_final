<mxfile host="app.diagrams.net" modified="2026-04-08T00:00:00.000Z" agent="Codex" version="24.7.17" compressed="false">
  <diagram id="task-execution-flow" name="任务执行流程">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="lane1" value="Coordinator" style="swimlane;whiteSpace=wrap;html=1;startSize=36;horizontal=0;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="300" height="860" as="geometry"/>
        </mxCell>
        <mxCell id="lane2" value="InterSatComm" style="swimlane;whiteSpace=wrap;html=1;startSize=36;horizontal=0;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="40" width="260" height="860" as="geometry"/>
        </mxCell>
        <mxCell id="lane3" value="SatelliteSimulator" style="swimlane;whiteSpace=wrap;html=1;startSize=36;horizontal=0;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="40" width="320" height="860" as="geometry"/>
        </mxCell>
        <mxCell id="lane4" value="GenericExecutor" style="swimlane;whiteSpace=wrap;html=1;startSize=36;horizontal=0;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1040" y="40" width="340" height="860" as="geometry"/>
        </mxCell>

        <mxCell id="c1" value="1. 启动任务执行&#xa;Coordinator::run()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="lane1">
          <mxGeometry x="40" y="70" width="220" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="c2" value="2. 根据调度结果&#xa;按卫星组织任务批次" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="lane1">
          <mxGeometry x="40" y="170" width="220" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="c3" value="3. 构造 BATCH_TASK_ASSIGN&#xa;包含该卫星全部任务" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="lane1">
          <mxGeometry x="40" y="280" width="220" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="c4" value="10. 接收回执消息&#xa;TASK_PROGRESS / TASK_COMPLETE / ACK" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="lane1">
          <mxGeometry x="40" y="560" width="220" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="c5" value="11. 更新任务状态&#xa;等待所有卫星完成或超时" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="lane1">
          <mxGeometry x="40" y="690" width="220" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="c6" value="12. 统计成功 / 失败卫星数量&#xa;输出最终执行结果" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="lane1">
          <mxGeometry x="40" y="810" width="220" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="m1" value="4. sendMessage()&#xa;投递批量任务消息" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=13;" vertex="1" parent="lane2">
          <mxGeometry x="30" y="300" width="180" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="m2" value="5. 本地 handler 直投&#xa;转发给目标卫星模拟器" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=13;" vertex="1" parent="lane2">
          <mxGeometry x="30" y="410" width="180" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="m3" value="9. sendMessage()&#xa;回传进度、完成和 ACK" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=13;" vertex="1" parent="lane2">
          <mxGeometry x="30" y="560" width="180" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="s1" value="6. handleBatchTaskAssign()&#xa;解析批量任务消息" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=13;" vertex="1" parent="lane3">
          <mxGeometry x="50" y="320" width="220" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="s2" value="7. 逐条遍历任务&#xa;转换为 TaskSegment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=13;" vertex="1" parent="lane3">
          <mxGeometry x="50" y="430" width="220" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="s3" value="8. 加载 / 缓存行为定义&#xa;behavior_ref -&gt; BehaviorNode" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=13;" vertex="1" parent="lane3">
          <mxGeometry x="50" y="540" width="220" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="s4" value="9. 调用执行器&#xa;executor_-&gt;executeTask()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=13;" vertex="1" parent="lane3">
          <mxGeometry x="50" y="660" width="220" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="s5" value="9+. 组织执行结果&#xa;发送 TASK_PROGRESS / TASK_COMPLETE / ACK" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=13;" vertex="1" parent="lane3">
          <mxGeometry x="50" y="780" width="220" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="g1" value="8.1 初始化任务上下文&#xa;写入 satellite_id / task_id / segment_id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="lane4">
          <mxGeometry x="50" y="180" width="240" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="g2" value="8.2 实例化行为树&#xa;加载默认变量、常量、运行参数" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="lane4">
          <mxGeometry x="50" y="300" width="240" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="g3" value="8.3 递归执行节点&#xa;Sequence / Selector / Action / Condition" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="lane4">
          <mxGeometry x="50" y="420" width="240" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="g4" value="8.4 执行内置命令&#xa;ASSIGN / MOVE_TO / SEND / RECEIVE ..." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="lane4">
          <mxGeometry x="50" y="540" width="240" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="g5" value="8.5 汇总结果并清理上下文&#xa;失败时按快照回滚变量状态" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="lane4">
          <mxGeometry x="50" y="660" width="240" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="n1" value="说明：当前默认是单进程仿真，InterSatComm 优先走本地 handler，因此任务消息通常不会进入真实网络发送链路。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="460" y="920" width="520" height="60" as="geometry"/>
        </mxCell>

