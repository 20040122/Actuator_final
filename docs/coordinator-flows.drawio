<mxfile host="app.diagrams.net" modified="2026-04-08T00:00:00.000Z" agent="Codex" version="24.7.17" compressed="false">
  <diagram id="coordinator-init-flow" name="协调器初始化流程">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="start1" value="开始&#xa;Coordinator::initialize()" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="420" y="40" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="step1" value="1. 加载调度文件&#xa;读取 schedule.json&#xa;得到卫星列表与任务列表" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="360" y="130" width="300" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="step2" value="2. 初始化 NodeRegistry&#xa;建立节点注册表" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="360" y="240" width="300" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="step3" value="3. 注册所有卫星节点&#xa;根据调度结果创建节点信息" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="360" y="340" width="300" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="step4" value="4. 初始化 InterSatComm&#xa;建立通信模块与消息能力" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="360" y="450" width="300" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="step5" value="5. 创建 SatelliteSimulator&#xa;为每颗卫星构造模拟器实例" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="360" y="560" width="300" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="step6" value="6. 初始化消息路由表&#xa;建立消息类型到处理函数的映射" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="360" y="670" width="300" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="step7" value="7. 注册本地消息处理器&#xa;为协调器和各卫星绑定 handler" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="360" y="780" width="300" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="end1" value="初始化完成&#xa;具备任务分发、回执接收、行为树执行能力" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="390" y="900" width="240" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="start1" target="step1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="step1" target="step2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="step2" target="step3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="step3" target="step4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="step4" target="step5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="step5" target="step6">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="step6" target="step7">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="step7" target="end1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="coordinator-run-flow" name="任务执行流程">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="start2" value="开始&#xa;Coordinator::run()" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="420" y="40" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="run1" value="1. 启动通信模块&#xa;comm_-&gt;start()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="360" y="130" width="300" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="run2" value="2. 初始化任务跟踪状态&#xa;为每颗卫星记录 expected / finished / result" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="330" y="230" width="360" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="run3" value="3. 分发批量任务&#xa;distributeAllTasks()&#xa;按卫星发送 BATCH_TASK_ASSIGN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="330" y="340" width="360" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="run4" value="4. 等待卫星 ACK&#xa;接收 BATCH_TASK_ASSIGN_ACK" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="385" y="470" width="250" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="run5" value="5. 60 秒内统计结果&#xa;未完成卫星标记为失败" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="360" y="610" width="300" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="run6" value="6. 输出成功 / 失败卫星数量&#xa;结束本轮运行" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="360" y="720" width="300" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="end2" value="运行结束" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="420" y="840" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="note1" value="卫星侧会执行任务并回传：&#xa;TASK_PROGRESS / TASK_COMPLETE / BATCH_TASK_ASSIGN_ACK" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="740" y="350" width="300" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="e21" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="start2" target="run1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e22" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="run1" target="run2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e23" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="run2" target="run3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e24" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="run3" target="run4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e25" value="收到 / 超时" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="run4" target="run5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e26" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="run5" target="run6">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e27" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="run6" target="end2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e28" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;endArrow=open;endFill=0;" edge="1" parent="1" source="run3" target="note1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
